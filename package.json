{
  "name": "ops-dashboard-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "npm run check-tokens && npm run check-guarded-token-drift && npm run check-stories && npm run check-module-boundaries",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:smoke": "playwright test",
    "test:smoke:external": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "test:smoke:mobile": "playwright test --config=playwright.mobile.config.ts",
    "test:smoke:mobile:external": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test --config=playwright.mobile.config.ts",
    "test:smoke:campaigns": "PLAYWRIGHT_WEB_SERVER_PORT=3002 playwright test tests/e2e/campaigns-module.spec.ts",
    "test:smoke:campaigns:frontend": "PLAYWRIGHT_WEB_SERVER_PORT=3002 playwright test tests/e2e/frontend-smoke.spec.ts",
    "test:smoke:campaigns:mobile": "PLAYWRIGHT_WEB_SERVER_PORT=3002 playwright test --config=playwright.mobile.config.ts tests/e2e/mobile-clickpaths.spec.ts",
    "test:smoke:slides:external": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test tests/e2e/slides-regression.spec.ts tests/e2e/slides-visual.spec.ts",
    "test:smoke:all": "npm run test:smoke && npm run test:smoke:mobile",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check-tokens": "node scripts/check-tokens.mjs",
    "check-guarded-token-drift": "node scripts/check-guarded-token-drift.mjs",
    "check-stories": "node scripts/check-user-stories.mjs",
    "check-module-boundaries": "node scripts/check-module-boundaries.mjs",
    "check-epic-size": "node scripts/check-epic-size.mjs",
    "check-epic-size:strict": "node scripts/check-epic-size.mjs --strict"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.7.0",
    "@supabase/supabase-js": "^2.103.3",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
